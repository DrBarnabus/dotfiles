[include]
	path = ~/.gitconfig.local
[user]
	email = 16451892+DrBarnabus@users.noreply.github.com
	name = Daniel Woodward
[core]
	excludesfile = ~/.gitignore
	fsmonitor = true
	untrackedCache = true
	pager = delta
[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true
	dark = true
[init]
	defaultBranch = main
[column]
	ui = auto
[branch]
	sort = -committerdate
[tag]
	sort = version:refname
[diff]
	algorithm = histogram
	colorMoved = plain
	mnemonicPrefix = true
	renames = true
[push]
	default = simple
	autoSetupRemote = true
	followTags = true
[fetch]
	prune = true
	pruneTags = true
	all = true
[pull]
	rebase = true
[commit]
	verbose = true
[rebase]
	autoSquash = true
	autoStash = true
	updateRefs = true
[merge]
	conflictstyle = zdiff3
[rerere]
	enabled = true
	autoUpdate = true
[help]
	autocorrect = prompt
[checkout]
	workers = 0
[index]
	threads = 0
[alias]
	fpush = push --force-with-lease
	lol = log --color --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit -10
