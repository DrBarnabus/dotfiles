{
  "project_panel": {
    "hide_gitignore": true
  },
  "cli_default_open_behavior": "existing_window",
  "title_bar": {
    "show_sign_in": false
  },
  "theme": "Catppuccin Mocha",
  "icon_theme": "Catppuccin Mocha",
  "auto_install_extensions": {
    "catppuccin": true,
    "catppuccin-icons": true
  },
  "prettier": {
    "allowed": true
  },
  "vim": {
    "toggle_relative_line_numbers": true
  }
}
