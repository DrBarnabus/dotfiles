{
  "$schema": "./dotfiles.schema.json",
  "groups": [
    {
      "name": "claude",
      "sources": [
        {
          "path": "~/.claude/commands",
          "type": "directory"
        },
        {
          "path": "~/.claude/scripts",
          "type": "directory"
        },
        {
          "path": "~/.claude/CLAUDE.md",
          "type": "file"
        },
        {
          "path": "~/.claude/settings.json",
          "type": "file"
        },
        {
          "path": "~/.claude.json",
          "type": "file",
          "extract": {
            "field": "mcpServers",
            "target": "mcp-servers.json"
          }
        }
      ]
    },
    {
      "name": "nvim",
      "sources": [
        {
          "path": "~/.config/nvim",
          "type": "directory",
          "symlink_mode": "directory"
        }
      ]
    },
    {
      "name": "tmux",
      "sources": [
        {
          "path": "~/.config/tmux",
          "type": "directory",
          "symlink_mode": "directory",
          "platforms": ["!windows"]
        }
      ]
    },
    {
      "name": "zsh",
      "sources": [
        {
          "path": "~/.theme.omp.toml",
          "type": "file"
        },
        {
          "path": "~/.zshrc",
          "type": "file",
          "platforms": ["!windows"]
        }
      ]
    }
  ]
}
