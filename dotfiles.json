{
  "$schema": "./dotfiles.schema.json",
  "groups": [
    {
      "name": "claude",
      "sources": [
        {
          "path": "~/.claude/hooks",
          "type": "directory"
        },
        {
          "path": "~/.claude/skills",
          "type": "directory"
        },
        {
          "path": "~/.claude/agents",
          "type": "directory"
        },
        {
          "path": "~/.claude/rules",
          "type": "directory"
        },
        {
          "path": "~/.claude/CLAUDE.md",
          "type": "file"
        },
        {
          "path": "~/.claude/settings.json",
          "type": "file"
        },
        {
          "path": "~/.claude.json",
          "type": "file",
          "extract": {
            "field": "mcpServers",
            "target": "mcp-servers.json"
          }
        }
      ]
    },
    {
      "name": "nvim",
      "sources": [
        {
          "path": "~/.config/nvim",
          "type": "directory",
          "symlink_mode": "directory"
        }
      ]
    },
    {
      "name": "tmux",
      "sources": [
        {
          "path": "~/.config/tmux",
          "type": "directory",
          "symlink_mode": "directory",
          "platforms": ["!windows"]
        }
      ]
    },
    {
      "name": "oh-my-posh",
      "sources": [
        {
          "path": "~/.theme.omp.toml",
          "type": "file"
        }
      ]
    },
    {
      "name": "git",
      "sources": [
        {
          "path": "~/.gitconfig",
          "type": "file"
        },
        {
          "path": "~/.gitignore",
          "type": "file"
        }
      ]
    },
    {
      "name": "bash",
      "sources": [
        {
          "path": "~/.bashrc",
          "type": "file",
          "platforms": ["windows"]
        }
      ]
    },
    {
      "name": "zsh",
      "sources": [
        {
          "path": "~/.zshrc",
          "type": "file"
        },
        {
          "path": "~/.zshrc.d",
          "type": "directory"
        }
      ]
    },
    {
      "name": "ghostty",
      "sources": [
        {
          "path": "~/.config/ghostty",
          "type": "directory",
          "symlink_mode": "directory",
          "platforms": ["!windows"]
        }
      ]
    },
    {
      "name": "windows-terminal",
      "sources": [
        {
          "path": "~/AppData/Local/Packages/Microsoft.WindowsTerminal_8wekyb3d8bbwe/LocalState/settings.json",
          "type": "file",
          "platforms": ["windows"]
        }
      ]
    }
  ]
}
