# Backup directory (contains user's original files before symlinking)
backups/

# Local overrides (machine-specific)
dotfiles.local.json

# Machine-local shell secrets (API keys, tokens)
files/zsh/.zshrc.d/env.zsh

# Temporary files
*.tmp
*.swp
*.swo
*~

# OS-specific files
.DS_Store
Thumbs.db

# Editor directories
.vscode/
.idea/

# Logs
*.log

# Python
__pycache__/
*.pyc

# Node (if using any JS tools)
node_modules/

# TPM installs plugins into the symlinked tmux config directory
files/tmux/plugins/
